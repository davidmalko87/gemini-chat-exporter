# Normalize line endings to LF in the repository for all text files.
* text=auto eol=lf

# Explicit text types.
*.py    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf

# Binary types (never normalize).
*.png   binary
*.jpg   binary
*.zip   binary
