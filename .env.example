# Gemini Chat Exporter - optional configuration.
# Everything here has a sensible default; copy this file to .env ONLY to override.
# .env is gitignored. This tool needs no credentials or API tokens.

# Where converted output (per-conversation JSON/Markdown + manifest) is written.
OUTPUT_ROOT=./out

# Verifier: FAIL when more than this fraction (0..1) of conversations share a
# body with another conversation (the duplicate-stub corruption fingerprint).
DUP_RATIO_FAIL=0.02

# Verifier: minimum length of a consecutive same-body run to flag as a run.
MIN_RUN=5

# Output toggles.
WRITE_JSON=true
WRITE_MARKDOWN=true
